{
  "family": "hello-deploy-td",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::078426574694:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "hello-deploy-container",
      "image": "078426574694.dkr.ecr.ap-southeast-2.amazonaws.com/hello-deploy-images:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ]
}
